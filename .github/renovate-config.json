{
    // see https://docs.renovatebot.com/self-hosted-configuration
    "$schema": "https://docs.renovatebot.com/renovate-global-schema.json",
    // "dryRun": "full",
    "branchPrefix": "renovate/",
    "username": "renovate",
    "gitAuthor": "Renovate Bot <bot@renovateapp.com>",
    "onboarding": false,
    "platform": "github",
    "forkProcessing": "enabled",
    "configMigration": true,
    "repositories": [
        "joholl/tpm2-tss" // TODO: change me
    ],
    "packageRules": [
        {
            "description": "Group ghcr.io/tpm2-software Docker images into one PR",
            "matchDatasources": [
                "docker"
            ],
            "matchPackagePatterns": ["^ghcr\\.io\\/tpm2-software\\/.+"],
            "groupName": "ghcr.io/tpm2-software images"
        }
    ]
}